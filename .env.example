# LAMS Production Environment Variables
# ============================================================================
# SECURITY WARNING:
# - Generate unique SECRET_KEY: python -c 'from secrets import token_urlsafe; print(token_urlsafe(32))'
# - Use strong POSTGRES_PASSWORD (16+ characters, mixed case, numbers, symbols)
# - NEVER commit .env file to version control
# - Set file permissions: chmod 600 .env
# ============================================================================

# Environment Type (development, staging, production)
# Phase 3.3: In production, /docs, /redoc, and /openapi.json are disabled
# This prevents token exposure in URL query params
ENVIRONMENT=production

# Domain Configuration
DOMAIN=lams.example.com
API_DOMAIN=api.lams.example.com
TRAEFIK_DOMAIN=traefik.lams.example.com

# SSL/TLS Configuration
ACME_EMAIL=admin@example.com
# Use staging for testing: https://acme-staging-v02.api.letsencrypt.org/directory
# Use production: https://acme-v02.api.letsencrypt.org/directory
ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory

# Database Configuration
POSTGRES_USER=lams
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
POSTGRES_DB=lams
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Backend Configuration
SECRET_KEY=CHANGE_THIS_TO_RANDOM_64_CHAR_HEX
ALGORITHM=HS256

# Phase 2.7: Token expiration settings
ACCESS_TOKEN_EXPIRE_MINUTES=60  # 1 hour (reduced from 8 days in Phase 2)
REFRESH_TOKEN_EXPIRE_DAYS=7     # 7 days

# CORS Configuration
# Comma-separated list of allowed origins (NEVER use "*" in production!)
# Example: https://lams.example.com,https://app.example.com
ALLOWED_ORIGINS=https://${DOMAIN}

# Phase 2.6: Logging Configuration
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Admin User (created on first startup)
ADMIN_EMAIL=admin@lams.io
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD

# Timezone
TZ=Europe/Madrid

# Rate Limiting
RATE_LIMIT_AVERAGE=100
RATE_LIMIT_BURST=50
API_RATE_LIMIT_AVERAGE=500
API_RATE_LIMIT_BURST=200

# Frontend Configuration
NEXT_PUBLIC_API_URL=https://api.lams.example.com
NEXT_TELEMETRY_DISABLED=1

# Monitoring (optional)
ENABLE_METRICS=true
ENABLE_TRACING=false

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="0 2 * * *"  # 2 AM daily

# Data Retention Policy
METRICS_RETENTION_DAYS=30        # Delete metrics older than X days
METRICS_AGGREGATION_DAYS=7       # Aggregate metrics older than X days into hourly summaries
CLEANUP_SCHEDULE_HOUR=2          # Hour to run cleanup job (24h format)
CLEANUP_SCHEDULE_MINUTE=0        # Minute to run cleanup job

# Agent Authentication
# Generate with: python -c 'from secrets import token_urlsafe; print(token_urlsafe(32))'
LAMS_AGENT_TOKEN=GENERATE_SECURE_TOKEN_HERE
LAMS_SERVER_URL=https://api.lams.example.com

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
